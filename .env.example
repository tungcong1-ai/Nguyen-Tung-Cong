# GEMINI_API_KEY: Required for Gemini AI API calls.
# Get your API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted.
# For local development, use http://localhost:3000
APP_URL="http://localhost:3000"

# FIREBASE CONFIGURATION
# This app uses firebase-applet-config.json for Firebase settings.
# When downloading, ensure you have your own Firebase project set up.
# You can also move these to .env if you modify src/firebase.ts to use import.meta.env
